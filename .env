# Server Configuration
NODE_ENV=development
PORT=3003

# Database Configuration (PostgreSQL)
# IMPORTANT: Update this with your actual PostgreSQL credentials
DATABASE_URL="postgresql://username:password@localhost:5432/scribeboard_db?schema=public"

# JWT Configuration
JWT_ACCESS_SECRET=scribeboard-access-secret-key-32chars
JWT_REFRESH_SECRET=scribeboard-refresh-secret-key-32chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Security
BCRYPT_SALT_ROUNDS=12

# CORS
CORS_ORIGIN=http://localhost:3000

# Comment Settings
AUTO_APPROVE_COMMENTS=false
